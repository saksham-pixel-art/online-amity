        function switchTab(type) {
            const grid = document.getElementById('course-grid');
            grid.innerHTML = '';
            
            // Manage Tab Styles
            ['ug', 'mba', 'mca'].forEach(id => {
                const btn = document.getElementById(`tab-${id}`);
                btn.classList.remove('tab-active', 'text-trust-navy', 'font-bold');
                btn.classList.add('text-on-surface-variant');
            });
            
            const activeBtn = document.getElementById(`tab-${type}`);
            activeBtn.classList.add('tab-active');
            activeBtn.classList.remove('text-on-surface-variant');

            // Render Courses
            courses[type].forEach(course => {
                const card = `
                    <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-outline-variant/30 group">
                        <div class="relative h-48 overflow-hidden">
                            <img src="${course.img}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" data-alt="A professional student studying on a laptop in a modern, sun-drenched library environment with sleek architectural lines. The lighting is soft and airy, creating an inspirational and focused academic mood. The color palette features deep navy accents and warm gold highlights, aligning with the prestige tech brand identity of Amity University Online.">
                            <div class="absolute top-4 left-4 bg-excellence-gold text-trust-navy text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">${course.tag}</div>
                        </div>
                        <div class="p-6">
                            <h4 class="font-headline-md text-headline-md text-trust-navy mb-4 h-16 overflow-hidden">${course.title}</h4>
                            <div class="flex items-center justify-between">
